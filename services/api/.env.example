PORT=4000
DATABASE_URL=postgresql://postgres:password@localhost:5432/flowbond
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3003,http://localhost:3010

# FlowEdit auth
FLOWEDIT_JWT_SECRET=change-me-in-production

# Base URLs (used to build approve/reject links in notifications)
API_BASE_URL=http://localhost:4000
FLOWEDIT_DASHBOARD_URL=http://localhost:3003

# Webhook: generic notify target (Make.com, Slack, etc.) — optional
# FLOWEDIT_NOTIFY_WEBHOOK=https://hook.make.com/your-webhook-url

# Webhook: FlowDesk integration — receives draft/approved/rejected events
FLOWDESK_WEBHOOK_URL=http://localhost:3010/api/webhooks/flowedit
FLOWEDIT_WEBHOOK_SECRET=same-secret-as-in-flowdesk-env

# AI (for parseContentChange via Claude)
ANTHROPIC_API_KEY=your-anthropic-key
