# ─── Tapo Camera ──────────────────────────────────────────────────────────────
# Get these from: Tapo app → Camera settings → Advanced → Camera Account
TAPO_IP=192.168.1.xxx
TAPO_USER=your_camera_username
TAPO_PASS=your_camera_password

# Stream quality: stream1 = 1080p main, stream2 = lower res sub-stream
TAPO_STREAM=stream1

# ─── FlowGarden ───────────────────────────────────────────────────────────────
FLOWGARDEN_API_URL=http://localhost:3002

# Device ID as registered in FlowGarden devices
DEVICE_ID=cam-lake-castle-back

# Zone ID the camera covers
ZONE_ID=zone-lake-castle-back

# ─── Capture settings ─────────────────────────────────────────────────────────
# How often to capture a frame (seconds)
CAPTURE_INTERVAL_SECONDS=300

# Where to save JPEG snapshots (served by Next.js)
SNAPSHOT_DIR=../flowgarden/public/captures
