NEXT_PUBLIC_SUPABASE_URL="https://fgsrcxxccdjqyrpkitmk.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# FBID hub (dev: http://localhost:3020 · prod: https://fbid.flowbond.life)
NEXT_PUBLIC_FBID_URL="https://fbid.flowbond.life"

# ── Private-cloud inference (cloud mode only) ──────────────────────────
# The relay holds this server-side. It is NEVER exposed to the browser.
# Anthropic must be on Commercial Terms (no training) + Zero Data Retention.
ANTHROPIC_API_KEY=""
CLAUDIA_MODEL="claude-sonnet-4-6"
# Optional: a stronger model for the SafeFlow Pro tier (falls back to CLAUDIA_MODEL).
CLAUDIA_MODEL_PRO="claude-opus-4-8"

# ── SafeFlow billing (plug-and-play tiers) ─────────────────────────────
# Stripe, used WITHOUT the SDK (REST + HMAC verify). Leave blank to disable
# billing (tiers can still be set manually by a superadmin via claudia_set_entitlement).
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""           # from the Stripe webhook endpoint you create
STRIPE_PRICE_PLUS=""               # Stripe price id that grants the Plus tier
STRIPE_PRICE_PRO=""                # Stripe price id that grants the Pro tier

# NOTE (§0): SUPABASE_SERVICE_ROLE_KEY is used server-side ONLY by the
# claudia-watch edge function (care engine) and the SafeFlow billing webhook
# (writes tier metadata, never ciphertext) — never in the browser. Even with it,
# an attacker recovers zero plaintext: all content is client-encrypted ciphertext.
SUPABASE_SERVICE_ROLE_KEY=""
