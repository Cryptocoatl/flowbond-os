# ── Supabase — canonical FlowBond project (fgsrcxxccdjqyrpkitmk, us-east-2) ──
NEXT_PUBLIC_SUPABASE_URL="https://fgsrcxxccdjqyrpkitmk.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Server-only. Never NEXT_PUBLIC_. Used by trusted API routes (DocuSign webhook).
SUPABASE_SERVICE_ROLE_KEY=""

# Public site origin (auth magic-link redirect target).
NEXT_PUBLIC_SITE_URL="https://flowme.one/separationagreement"

# ── DocuSign eSignature (server-only, JWT grant) ────────────────────────────
# All optional at build time; required only to drive live signing.
DOCUSIGN_BASE_URL="https://demo.docusign.net/restapi"          # account-d for prod
DOCUSIGN_OAUTH_BASE="account-d.docusign.com"                   # account.docusign.com for prod
DOCUSIGN_INTEGRATION_KEY=""                                    # client/integration key (GUID)
DOCUSIGN_USER_ID=""                                            # impersonated user GUID
DOCUSIGN_ACCOUNT_ID=""                                         # API account id (GUID)
DOCUSIGN_PRIVATE_KEY=""                                        # RSA private key PEM (\n-escaped or raw)
DOCUSIGN_CONNECT_HMAC_KEY=""                                   # Connect webhook HMAC secret

# ── Base (L2) anchoring (optional; client wallet pays gas) ──────────────────
NEXT_PUBLIC_BASE_CHAIN_ID="8453"                              # 8453 mainnet · 84532 sepolia
NEXT_PUBLIC_BASE_RPC_URL="https://mainnet.base.org"
# EAS on Base (preferred). If unset, the app uses the minimal anchor contract below.
NEXT_PUBLIC_EAS_CONTRACT="0x4200000000000000000000000000000000000021"
NEXT_PUBLIC_EAS_SCHEMA_UID=""                                 # schema (bytes32 dealId, bytes32 packageHash, string status)
NEXT_PUBLIC_FLOWSCROW_ANCHOR_CONTRACT=""                      # fallback FlowScrowAnchor address
