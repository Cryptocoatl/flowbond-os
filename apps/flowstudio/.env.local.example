# ── FlowStudio · AI Video Edit ────────────────────────────────────────────────
# Copy to .env.local and fill. v1 only NEEDS FAL_KEY. Everything else is optional
# and lazy-loaded (the build does not require the optional SDKs to be installed).

# L1 generation — PRIMARY (one key → Kling / Veo / Seedance via fal.ai)
FAL_KEY=

# L1 generation — OPTIONAL specialty providers (install the SDK before enabling)
#   pnpm add @google/genai     → Veo 3.1 direct (only when 48kHz synced dialogue is needed)
GOOGLE_GENAI_API_KEY=
#   pnpm add @runwayml/sdk     → Runway Gen-4 (motion brush / control shots)
RUNWAYML_API_SECRET=

# L6 provenance — Origo (honest AI-assisted labeling + Proof-of-Human)
ORIGO_API_URL=https://origo.flowme.one/api
ORIGO_API_KEY=
STORY_PROTOCOL_RPC=

# Asset index (RULES.md: every asset gets a row in public.video_assets).
# Canonical Supabase: fgsrcxxccdjqyrpkitmk (us-east-2)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_SITE_URL=https://studio.flowbond.life

# Tooling overrides (defaults assume both are on PATH)
FFMPEG_BIN=ffmpeg
PYTHON_BIN=python3
# Where renders + handoff packages land (defaults to ~/FlowStudio per RULES.md)
FLOWSTUDIO_ROOT=
