# ─── Interop services (Tianguis market) ───────────────────────────────────────
# RefiRides delivery dispatch. Optional — defaults to the public prod URL.
REFIRIDES_API_URL=https://refirides-sigma.vercel.app
# FlowScrow payment escrow. DORMANT unless set: blank = orders placed with no
# hold. Set once FlowScrow is deployed and exposes /api/escrow/{open,release,void}.
FLOWSCROW_API_URL=
